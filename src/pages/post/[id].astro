---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'
import 'github-markdown-css/github-markdown.css'
import '../../styles/markdown.css'


export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)
const title = post.data.title
---

<Layout title={title}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <time class="post-published">发表于 {post.data.published.toISOString().slice(0, 19).replace('T', ' ')}</time>
    </header>
    <div class="post-content markdown-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .post {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 1rem 0;
  }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-title {
    font-size: calc(var(--text-title-fontsize) + 8px);
    font-weight: var(--text-weight);
    color: var(--text-title-color);
    margin: 0;
  }

  .post-published {
    font-size: calc(var(--text-content-fontsize) - 2px);
    color: var(--text-content-color);
  }
  .post-content {
    font-size: var(--text-content-fontsize);
    line-height: 1.8;
  }
</style>
