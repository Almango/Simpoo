---
import Layout from '../../layouts/Layout.astro'
import Turnpage from '../../components/Turnpage.astro'
import { getCollection } from 'astro:content'
import { POST_CONFIG } from '../../config'

const POSTS_PER_PAGE = POST_CONFIG.page_size

export async function getStaticPaths() {
  const POSTS_PER_PAGE = POST_CONFIG.page_size
  
  const posts = await getCollection('posts')
  
  const totalPosts = posts.length
  const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE)
  
  const paths = []
  
  // 从第 2 页开始生成，第 1 页是首页
  for (let i = 2; i <= totalPages; i++) {
    paths.push({
      params: { page: i.toString() },
    })
  }
  
  return paths
}

const page = Number(Astro.params.page) || 2

const posts = await getCollection('posts')

const totalPosts = posts.length
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE)

posts.sort((a, b) => new Date(b.data.published).getTime() - new Date(a.data.published).getTime())

const startIndex = (page - 1) * POSTS_PER_PAGE
const paginatedPosts = posts.slice(startIndex, startIndex + POSTS_PER_PAGE)
---

<Layout title={`第 ${page} 页 | Almango`}>
  <ul class="post">
    {paginatedPosts.map(post => (
      <li class="post-item">
        <a href={`/post/${post.id}`} class="post-link">
          <h2 class="post-title">{post.data.title}</h2>
          {post.data.description && <p class="post-description">{post.data.description}</p>}
          <span class="post-published">{post.data.published.toISOString().split('T')[0]}</span>
        </a>
      </li>
    ))}
  </ul>
  <Turnpage currentPage={page} totalPages={totalPages} baseUrl="/page" />
</Layout>

<style>
  .post {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    padding: 1rem 0;
  }

  .post-link {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: inherit;
  }

  .post-title {
    font-size: var(--text-title-fontsize);
    font-weight: 500;
    color: var(--text-title-color);
    margin: 0;
  }

  .post-description {
    font-size: calc(var(--text-description-fontsize) + 2.5px);
    color: var(--text-description-color);
    margin: 0;
  }

  .post-published {
    font-size: var(--text-description-fontsize);
    color: var(--text-description-color);
  }
</style>
