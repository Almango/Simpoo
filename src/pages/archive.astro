---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('posts')
const posts = allPosts.sort((a, b) => {
  return new Date(b.data.published).getTime() - new Date(a.data.published).getTime()
})

// 按年份分组
const groupedPosts = posts.reduce((acc, post) => {
  const year = new Date(post.data.published).getFullYear()
  if (!acc[year]) {
    acc[year] = []
  }
  acc[year].push(post)
  return acc
}, {} as Record<number, typeof posts>)

// 按年份降序排列
const years = Object.keys(groupedPosts).map(Number).sort((a, b) => b - a)

const title = '归档'
---

<Layout title={title}>
  <div class="archive">
    {years.map(year => (
      <section class="archive-year-section">
        <h2 class="archive-year">{year}</h2>
        <ul class="archive-list">
          {groupedPosts[year].map(post => (
            <li class="archive-item">
              <span class="archive-published">
                {post.data.published.toISOString().slice(5, 10)}
              </span>
              <a href={`/post/${post.id}`} class="archive-title">{post.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>

<style>
  .archive {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .archive-year-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .archive-year {
    font-size: calc(var(--text-title-fontsize) + 12px);
    font-weight: var(--text-weight);
    color: var(--text-title-color);
    margin: 0;
    padding-bottom: 0.5rem;  
  }

  .archive-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .archive-item {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .archive-published {
    font-size: var(--text-content-fontsize);
    color: var(--text-description-color);
    flex-shrink: 0;
    min-width: 3rem;
  }

  .archive-title {
    font-size: var(--text-content-fontsize);
    color: var(--text-content-color);
    text-decoration: none;
  }

  .archive-title:hover {
    color: var(--text-title-color);
  }
</style>
