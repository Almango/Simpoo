---
import Layout from '../layouts/Layout.astro'
import { links } from '../data/links.ts'

const title = '友链'
---

<Layout title={title}>
  <div class="link">
    <div class="link-top">
      {links.map(link => (
        <a href={link.url} target="_blank" rel="noopener" class="link-item">
          <img src={link.avatar} alt={link.name} class="link-avatar" />
          <span class="link-name">{link.name}</span>
        </a>
      ))}
    </div>
    <div class="link-bottom">
      <h3>友链申请</h3>
      <p>海内存知己，天涯若比邻：很高兴能在这里与你相遇，如果你也和我一样，热爱记录、用心经营自己的小天地，欢迎常来坐坐，期待与你交换友链，以站会友，天涯亦比邻。</p>
      <ul>
        <li>网站内容必须符合中国大陆法律法规</li>
        <li>网站能够正常访问，且无广告和恶意弹窗</li>
        <li>要求博客类网站，且拥有一定原创内容</li>
      </ul>
    </div>
  </div>
</Layout>

<style>
  .link {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 1rem 0;
  }

  .link-top {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .link-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .link-avatar {
    width: 2rem;
    height: 2rem;
    object-fit: cover;
  }

  .link-name {
    font-size: var(--text-content-fontsize);
    color: var(--text-content-color);
  }

  .link-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .link-bottom h3 {
    font-size: var(--text-title-fontsize);
    color: var(--text-title-color);
    margin: 0;
  }

  .link-bottom p {
    font-size: var(--text-content-fontsize);
    color: var(--text-content-color);
    margin: 0;
  }

  .link-bottom ul {
    margin: 0;
    padding-left: 1.5rem;
    font-size: calc(var(--text-content-fontsize) - 1px);
    color: var(--text-content-color);
  }

  .link-bottom li {
    margin: 0.28rem 0;
  }
</style>
